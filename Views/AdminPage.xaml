<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:dto="clr-namespace:ReStyle.Application.DTOs"
             xmlns:conv="clr-namespace:ReStyle.Converters"
             x:Class="ReStyle.Views.AdminPage"
             Title="Administraator">

    <ContentPage.Resources>
        <conv:BlockButtonTextConverter x:Key="BlockButtonTextConverter" />
        <conv:BlockButtonStyleConverter x:Key="BlockButtonStyleConverter" />
    </ContentPage.Resources>

    <CollectionView x:Name="UsersList" ItemsSource="{Binding Users}" Margin="16,8">
        <CollectionView.EmptyView>
            <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center"
                                 Spacing="12" Margin="0,80">
                <Label Text="👥" FontSize="72" HorizontalOptions="Center" />
                <Label Text="Kasutajaid ei leitud" Style="{StaticResource H2Label}"
                       HorizontalOptions="Center" />
            </VerticalStackLayout>
        </CollectionView.EmptyView>
        <CollectionView.ItemTemplate>
            <DataTemplate x:DataType="dto:UserDto">
                <Border Margin="0,5"
                        BackgroundColor="{StaticResource Surface}"
                        StrokeShape="RoundRectangle 16"
                        Stroke="{StaticResource Border}" StrokeThickness="1">
                    <Border.Shadow>
                        <Shadow Brush="{StaticResource TextPrimary}"
                                Offset="0,2" Radius="8" Opacity="0.05" />
                    </Border.Shadow>
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="0" Padding="14">
                        <!-- Avatar -->
                        <Border Grid.Column="0"
                                BackgroundColor="{StaticResource PrimarySubtle}"
                                StrokeShape="RoundRectangle 22"
                                Stroke="Transparent"
                                WidthRequest="44" HeightRequest="44"
                                Margin="0,0,12,0">
                            <Label Text="👤" FontSize="20"
                                   HorizontalOptions="Center" VerticalOptions="Center" />
                        </Border>
                        <!-- Info -->
                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                            <Label Text="{Binding Username}"
                                   FontSize="14" FontAttributes="Bold"
                                   TextColor="{StaticResource TextPrimary}" />
                            <Label Text="{Binding Email}"
                                   FontSize="12" TextColor="{StaticResource TextTertiary}"
                                   LineBreakMode="TailTruncation" MaxLines="1" />
                            <Border BackgroundColor="{StaticResource PrimarySubtle}"
                                    StrokeShape="RoundRectangle 6"
                                    Stroke="Transparent" Padding="6,2"
                                    HorizontalOptions="Start">
                                <Label Text="{Binding Role}" FontSize="10" FontAttributes="Bold"
                                       TextColor="{StaticResource Primary}" />
                            </Border>
                        </VerticalStackLayout>
                        <!-- Block/Unblock button -->
                        <Button Grid.Column="2"
                                Text="{Binding IsBlocked, Converter={StaticResource BlockButtonTextConverter}}"
                                Style="{Binding IsBlocked, Converter={StaticResource BlockButtonStyleConverter}}"
                                HeightRequest="36" Padding="14,0" FontSize="12"
                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.BlockUserCommand}"
                                CommandParameter="{Binding .}" />
                    </Grid>
                </Border>
            </DataTemplate>
        </CollectionView.ItemTemplate>
    </CollectionView>

</ContentPage>
