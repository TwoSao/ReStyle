<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:conv="clr-namespace:ReStyle.Converters"
             x:Class="ReStyle.Views.RegisterPage"
             Title="Registreeru"
             Shell.NavBarIsVisible="False">

    <ContentPage.Resources>
        <conv:NullToFalseConverter x:Key="NullToFalseConverter" />
        <conv:InverseBoolConverter x:Key="InverseBoolConverter" />
    </ContentPage.Resources>

    <ScrollView>
        <Grid RowDefinitions="200,*">

            <!-- ── Hero Header ── -->
            <Grid Grid.Row="0" BackgroundColor="{StaticResource HeaderBg}">
                <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="8">
                    <Border StrokeShape="RoundRectangle 24"
                            BackgroundColor="#FFFFFF18"
                            Stroke="Transparent"
                            WidthRequest="72" HeightRequest="72"
                            HorizontalOptions="Center">
                        <Label Text="✦" FontSize="32" TextColor="White"
                               HorizontalOptions="Center" VerticalOptions="Center" />
                    </Border>
                    <Label Text="Liitu ReStyle'iga" FontSize="28" FontAttributes="Bold"
                           TextColor="White" HorizontalOptions="Center" />
                    <Label Text="Alusta ostmist ja müümist juba täna" FontSize="13"
                           TextColor="#A5B4FC" HorizontalOptions="Center" />
                </VerticalStackLayout>
            </Grid>

            <!-- ── Form ── -->
            <VerticalStackLayout Grid.Row="1" Padding="24,0,24,32" Spacing="0">

                <Border Margin="0,-28,0,0"
                        BackgroundColor="{StaticResource Surface}"
                        StrokeShape="RoundRectangle 20"
                        Stroke="{StaticResource Border}"
                        Padding="24">
                    <Border.Shadow>
                        <Shadow Brush="{StaticResource TextPrimary}" Offset="0,4" Radius="20" Opacity="0.08" />
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="0">
                        <Label Text="Loo konto" Style="{StaticResource H2Label}" />
                        <Label Text="Täida oma andmed alustamiseks" Style="{StaticResource SubtitleLabel}"
                               Margin="0,4,0,20" />

                        <Label Text="KASUTAJANIMI" Style="{StaticResource FieldLabel}" />
                        <Entry Placeholder="nt maris" Text="{Binding Username}"
                               Style="{StaticResource ModernEntry}" />

                        <Label Text="E-POST" Style="{StaticResource FieldLabel}" />
                        <Entry Placeholder="sinu@email.ee" Text="{Binding Email}"
                               Keyboard="Email" Style="{StaticResource ModernEntry}" />

                        <Label Text="PAROOL" Style="{StaticResource FieldLabel}" />
                        <Entry Placeholder="Vähemalt 6 tähemärki" Text="{Binding Password}"
                               IsPassword="True" Style="{StaticResource ModernEntry}" />

                        <Label Text="KONFIRMEERI PAROOL" Style="{StaticResource FieldLabel}" />
                        <Entry Placeholder="Korda parooli" Text="{Binding ConfirmPassword}"
                               IsPassword="True" Style="{StaticResource ModernEntry}" />

                        <!-- Error -->
                        <Border IsVisible="{Binding ErrorMessage, Converter={StaticResource NullToFalseConverter}}"
                                BackgroundColor="{StaticResource ErrorSubtle}"
                                StrokeShape="RoundRectangle 10"
                                Stroke="Transparent"
                                Padding="12,10" Margin="0,12,0,0">
                            <Label Text="{Binding ErrorMessage}" FontSize="13"
                                   TextColor="{StaticResource ErrorDark}" />
                        </Border>

                        <Button Text="Loo konto" Style="{StaticResource PrimaryButton}"
                                Command="{Binding RegisterCommand}"
                                IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"
                                Margin="0,20,0,0" />

                        <ActivityIndicator IsRunning="{Binding IsBusy}"
                                           IsVisible="{Binding IsBusy}" />
                    </VerticalStackLayout>
                </Border>

                <HorizontalStackLayout HorizontalOptions="Center" Margin="0,20,0,0" Spacing="4">
                    <Label Text="Kas sul on juba konto?" Style="{StaticResource SubtitleLabel}"
                           VerticalOptions="Center" />
                    <Button Text="Logi sisse" Style="{StaticResource GhostButton}"
                            Command="{Binding GoToLoginCommand}"
                            FontAttributes="Bold" />
                </HorizontalStackLayout>

            </VerticalStackLayout>
        </Grid>
    </ScrollView>

</ContentPage>
