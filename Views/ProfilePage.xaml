<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:conv="clr-namespace:ReStyle.Converters"
             x:Class="ReStyle.Views.ProfilePage"
             Title="Profile">

    <ContentPage.Resources>
        <conv:InverseBoolConverter x:Key="InverseBoolConverter" />
        <conv:NullToFalseConverter x:Key="NullToFalseConverter" />
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Spacing="0">

            <!-- ════ GUEST ════ -->
            <VerticalStackLayout IsVisible="{Binding IsGuest}" Spacing="0">

                <Grid BackgroundColor="{StaticResource HeaderBg}" Padding="24,48,24,40">
                    <VerticalStackLayout Spacing="10" HorizontalOptions="Center">
                        <Border StrokeShape="RoundRectangle 40" Stroke="#FFFFFF30" StrokeThickness="2"
                                WidthRequest="80" HeightRequest="80" HorizontalOptions="Center"
                                BackgroundColor="#FFFFFF15">
                            <Label Text="👤" FontSize="34" HorizontalOptions="Center" VerticalOptions="Center" />
                        </Border>
                        <Label Text="Guest" FontSize="22" FontAttributes="Bold" TextColor="White"
                               HorizontalOptions="Center" />
                        <Label Text="Browsing without an account" FontSize="13"
                               TextColor="#A5B4FC" HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </Grid>

                <VerticalStackLayout Padding="20,24" Spacing="12">
                    <Border BackgroundColor="{StaticResource PrimarySubtle}"
                            StrokeShape="RoundRectangle 16" Stroke="Transparent" Padding="20">
                        <VerticalStackLayout Spacing="10">
                            <Label Text="Unlock the full experience" FontSize="16" FontAttributes="Bold"
                                   TextColor="{StaticResource PrimaryDark}" />
                            <Label Text="✦  Buy and sell fashion items" FontSize="14"
                                   TextColor="{StaticResource TextSecondary}" />
                            <Label Text="✦  Track your transactions" FontSize="14"
                                   TextColor="{StaticResource TextSecondary}" />
                            <Label Text="✦  Manage your listings" FontSize="14"
                                   TextColor="{StaticResource TextSecondary}" />
                            <Label Text="✦  Top up your balance" FontSize="14"
                                   TextColor="{StaticResource TextSecondary}" />
                        </VerticalStackLayout>
                    </Border>
                    <Button Text="Sign In" Style="{StaticResource PrimaryButton}"
                            Command="{Binding GoToLoginCommand}" />
                    <Button Text="Create Account" Style="{StaticResource SecondaryButton}"
                            Command="{Binding GoToRegisterCommand}" />
                </VerticalStackLayout>

            </VerticalStackLayout>

            <!-- ════ USER ════ -->
            <VerticalStackLayout IsVisible="{Binding IsUser}" Spacing="0">

                <!-- Header -->
                <Grid BackgroundColor="{StaticResource HeaderBg}" Padding="24,48,24,40">
                    <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                        <Border StrokeShape="RoundRectangle 40" Stroke="#FFFFFF30" StrokeThickness="2"
                                WidthRequest="80" HeightRequest="80" HorizontalOptions="Center"
                                BackgroundColor="{StaticResource Primary}">
                            <Label Text="👤" FontSize="34" HorizontalOptions="Center" VerticalOptions="Center" />
                        </Border>
                        <Label Text="{Binding Username}" FontSize="22" FontAttributes="Bold"
                               TextColor="White" HorizontalOptions="Center" />
                        <Border BackgroundColor="#FFFFFF20" StrokeShape="RoundRectangle 20"
                                Stroke="Transparent" Padding="12,4" HorizontalOptions="Center">
                            <Label Text="{Binding Role}" FontSize="12" TextColor="White" FontAttributes="Bold" />
                        </Border>
                    </VerticalStackLayout>
                </Grid>

                <VerticalStackLayout Padding="20,0,20,32" Spacing="0">

                    <!-- Balance card (pulled up) -->
                    <Border Margin="0,-24,0,0"
                            BackgroundColor="{StaticResource Surface}"
                            StrokeShape="RoundRectangle 20"
                            Stroke="{StaticResource Border}"
                            Padding="20">
                        <Border.Shadow>
                            <Shadow Brush="{StaticResource Primary}" Offset="0,4" Radius="16" Opacity="0.12" />
                        </Border.Shadow>
                        <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
                            <Label Grid.Row="0" Grid.Column="0" Text="BALANCE"
                                   Style="{StaticResource FieldLabel}" Margin="0" />
                            <Label Grid.Row="1" Grid.Column="0"
                                   Text="{Binding Balance, StringFormat='${0:F2}'}"
                                   FontSize="30" FontAttributes="Bold"
                                   TextColor="{StaticResource Primary}" />
                            <Button Grid.Row="0" Grid.Column="1" Grid.RowSpan="2"
                                    Text="Top Up" Style="{StaticResource PrimaryButton}"
                                    HeightRequest="44" Padding="16,0"
                                    VerticalOptions="Center"
                                    Command="{Binding GoToBalanceCommand}" />
                        </Grid>
                    </Border>

                    <!-- Edit profile -->
                    <Border Margin="0,16,0,0"
                            BackgroundColor="{StaticResource Surface}"
                            StrokeShape="RoundRectangle 16"
                            Stroke="{StaticResource Border}"
                            Padding="20">
                        <VerticalStackLayout Spacing="0">
                            <Label Text="Edit Profile" Style="{StaticResource H2Label}" FontSize="17" />
                            <Label Text="Update your personal info" Style="{StaticResource SubtitleLabel}"
                                   Margin="0,2,0,16" />

                            <Label Text="USERNAME" Style="{StaticResource FieldLabel}" />
                            <Entry Placeholder="Username" Text="{Binding Username}"
                                   Style="{StaticResource ModernEntry}" />

                            <Label Text="EMAIL" Style="{StaticResource FieldLabel}" />
                            <Entry Placeholder="Email" Text="{Binding Email}"
                                   Keyboard="Email" Style="{StaticResource ModernEntry}" />

                            <Border IsVisible="{Binding ErrorMessage, Converter={StaticResource NullToFalseConverter}}"
                                    BackgroundColor="{StaticResource ErrorSubtle}"
                                    StrokeShape="RoundRectangle 10"
                                    Stroke="Transparent" Padding="12,10" Margin="0,8,0,0">
                                <Label Text="{Binding ErrorMessage}" FontSize="13"
                                       TextColor="{StaticResource ErrorDark}" />
                            </Border>

                            <Button Text="Save Changes" Style="{StaticResource PrimaryButton}"
                                    Command="{Binding SaveProfileCommand}"
                                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"
                                    Margin="0,16,0,0" />
                        </VerticalStackLayout>
                    </Border>

                    <!-- Quick actions -->
                    <Border Margin="0,12,0,0"
                            BackgroundColor="{StaticResource Surface}"
                            StrokeShape="RoundRectangle 16"
                            Stroke="{StaticResource Border}">
                        <VerticalStackLayout Spacing="0">
                            <!-- Transactions -->
                            <Grid Padding="20,16" ColumnDefinitions="Auto,*,Auto">
                                <Label Grid.Column="0" Text="📋" FontSize="18" VerticalOptions="Center" Margin="0,0,14,0" />
                                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                                    <Label Text="Transaction History" FontSize="15" FontAttributes="Bold"
                                           TextColor="{StaticResource TextPrimary}" />
                                    <Label Text="View purchases and sales" FontSize="12"
                                           TextColor="{StaticResource TextTertiary}" />
                                </VerticalStackLayout>
                                <Label Grid.Column="2" Text="›" FontSize="20"
                                       TextColor="{StaticResource TextTertiary}" VerticalOptions="Center" />
                                <Grid.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding GoToTransactionsCommand}" />
                                </Grid.GestureRecognizers>
                            </Grid>
                            <BoxView Style="{StaticResource HDivider}" Margin="20,0" />
                            <!-- Admin -->
                            <Grid Padding="20,16" ColumnDefinitions="Auto,*,Auto"
                                  IsVisible="{Binding IsAdmin}">
                                <Label Grid.Column="0" Text="🛡️" FontSize="18" VerticalOptions="Center" Margin="0,0,14,0" />
                                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                                    <Label Text="Admin Panel" FontSize="15" FontAttributes="Bold"
                                           TextColor="{StaticResource TextPrimary}" />
                                    <Label Text="Manage users and listings" FontSize="12"
                                           TextColor="{StaticResource TextTertiary}" />
                                </VerticalStackLayout>
                                <Label Grid.Column="2" Text="›" FontSize="20"
                                       TextColor="{StaticResource TextTertiary}" VerticalOptions="Center" />
                                <Grid.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding GoToAdminCommand}" />
                                </Grid.GestureRecognizers>
                            </Grid>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Sign out -->
                    <Button Text="Sign Out" Style="{StaticResource DangerButton}"
                            HorizontalOptions="Fill" HeightRequest="52"
                            CornerRadius="14" FontSize="15"
                            Margin="0,16,0,0"
                            Command="{Binding LogoutCommand}" />

                </VerticalStackLayout>
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
