<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:conv="clr-namespace:ReStyle.Converters"
             x:Class="ReStyle.Views.AddItemPage"
             Title="New Listing">

    <ContentPage.Resources>
        <conv:ImagePathConverter x:Key="ImagePathConverter" />
        <conv:NullToFalseConverter x:Key="NullToFalseConverter" />
        <conv:InverseBoolConverter x:Key="InverseBoolConverter" />
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Padding="20,16,20,40" Spacing="0">

            <!-- Photo picker -->
            <Border StrokeShape="RoundRectangle 16" Stroke="{StaticResource Border}"
                    HeightRequest="200" BackgroundColor="{StaticResource SurfaceVariant}"
                    Margin="0,0,0,20">
                <Grid>
                    <Image Source="{Binding ImagePath, Converter={StaticResource ImagePathConverter}}"
                           Aspect="AspectFill"
                           IsVisible="{Binding ImagePath, Converter={StaticResource NullToFalseConverter}}" />
                    <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="10"
                                         IsVisible="{Binding ImagePath, Converter={StaticResource InverseBoolConverter}}">
                        <Border BackgroundColor="{StaticResource PrimarySubtle}"
                                StrokeShape="RoundRectangle 24" Stroke="Transparent"
                                WidthRequest="60" HeightRequest="60" HorizontalOptions="Center">
                            <Label Text="📷" FontSize="28"
                                   HorizontalOptions="Center" VerticalOptions="Center" />
                        </Border>
                        <Label Text="Tap to add photo" FontSize="14" FontAttributes="Bold"
                               TextColor="{StaticResource Primary}" HorizontalOptions="Center" />
                        <Label Text="JPG, PNG supported" Style="{StaticResource CaptionLabel}"
                               HorizontalOptions="Center" />
                    </VerticalStackLayout>
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding PickImageCommand}" />
                    </Grid.GestureRecognizers>
                </Grid>
            </Border>

            <!-- Form -->
            <Border BackgroundColor="{StaticResource Surface}"
                    StrokeShape="RoundRectangle 16" Stroke="{StaticResource Border}"
                    Padding="20" Margin="0,0,0,16">
                <VerticalStackLayout Spacing="0">
                    <Label Text="Listing Details" Style="{StaticResource H2Label}" FontSize="17"
                           Margin="0,0,0,16" />

                    <Label Text="TITLE" Style="{StaticResource FieldLabel}" />
                    <Entry Placeholder="e.g. Vintage Denim Jacket"
                           Text="{Binding Title}" Style="{StaticResource ModernEntry}" />

                    <Label Text="DESCRIPTION" Style="{StaticResource FieldLabel}" />
                    <Border BackgroundColor="{StaticResource SurfaceVariant}"
                            StrokeShape="RoundRectangle 10" Stroke="Transparent"
                            Padding="14,10" Margin="0,2,0,0">
                        <Editor Placeholder="Describe condition, style, brand..."
                                Text="{Binding Description}"
                                Style="{StaticResource ModernEditor}"
                                HeightRequest="100"
                                BackgroundColor="Transparent" />
                    </Border>

                    <Label Text="PRICE ($)" Style="{StaticResource FieldLabel}" />
                    <Entry Placeholder="0.00" Text="{Binding Price}"
                           Keyboard="Numeric" Style="{StaticResource ModernEntry}" />
                </VerticalStackLayout>
            </Border>

            <!-- Category / Size -->
            <Border BackgroundColor="{StaticResource Surface}"
                    StrokeShape="RoundRectangle 16" Stroke="{StaticResource Border}"
                    Padding="20" Margin="0,0,0,16">
                <VerticalStackLayout Spacing="0">
                    <Label Text="Classification" Style="{StaticResource H2Label}" FontSize="17"
                           Margin="0,0,0,16" />

                    <Label Text="CATEGORY" Style="{StaticResource FieldLabel}" />
                    <Border BackgroundColor="{StaticResource SurfaceVariant}"
                            StrokeShape="RoundRectangle 10" Stroke="Transparent"
                            Padding="12,0" Margin="0,2,0,0" HeightRequest="52">
                        <Picker ItemsSource="{Binding Categories}" SelectedItem="{Binding Category}"
                                Title="Select category" Style="{StaticResource ModernPicker}"
                                BackgroundColor="Transparent" />
                    </Border>

                    <Label Text="SIZE" Style="{StaticResource FieldLabel}" />
                    <Border BackgroundColor="{StaticResource SurfaceVariant}"
                            StrokeShape="RoundRectangle 10" Stroke="Transparent"
                            Padding="12,0" Margin="0,2,0,0" HeightRequest="52">
                        <Picker ItemsSource="{Binding Sizes}" SelectedItem="{Binding Size}"
                                Title="Select size" Style="{StaticResource ModernPicker}"
                                BackgroundColor="Transparent" />
                    </Border>
                </VerticalStackLayout>
            </Border>

            <!-- Error -->
            <Border IsVisible="{Binding ErrorMessage, Converter={StaticResource NullToFalseConverter}}"
                    BackgroundColor="{StaticResource ErrorSubtle}"
                    StrokeShape="RoundRectangle 12" Stroke="Transparent"
                    Padding="16,12" Margin="0,0,0,12">
                <Label Text="{Binding ErrorMessage}" FontSize="13"
                       TextColor="{StaticResource ErrorDark}" />
            </Border>

            <!-- Actions -->
            <Button Text="Post Listing" Style="{StaticResource PrimaryButton}"
                    Command="{Binding SaveCommand}"
                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"
                    Margin="0,0,0,10" />
            <Button Text="Cancel" Style="{StaticResource SecondaryButton}"
                    Command="{Binding CancelCommand}" />
            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
