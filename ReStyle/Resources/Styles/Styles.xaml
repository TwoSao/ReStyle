<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="Colors.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <!-- ═══════════════════════════════════════════════ -->
    <!--  PAGE & SHELL                                   -->
    <!-- ═══════════════════════════════════════════════ -->
    <Style TargetType="ContentPage" ApplyToDerivedTypes="True">
        <Setter Property="BackgroundColor" Value="{DynamicResource Background}" />
    </Style>

    <Style TargetType="Shell" ApplyToDerivedTypes="True">
        <Setter Property="Shell.BackgroundColor" Value="{DynamicResource Surface}" />
        <Setter Property="Shell.ForegroundColor" Value="{DynamicResource Primary}" />
        <Setter Property="Shell.TitleColor" Value="{DynamicResource TextPrimary}" />
        <Setter Property="Shell.TabBarBackgroundColor" Value="{DynamicResource Surface}" />
        <Setter Property="Shell.TabBarForegroundColor" Value="{DynamicResource Primary}" />
        <Setter Property="Shell.TabBarUnselectedColor" Value="{DynamicResource TextTertiary}" />
        <Setter Property="Shell.TabBarTitleColor" Value="{DynamicResource Primary}" />
    </Style>

    <!-- ═══════════════════════════════════════════════ -->
    <!--  TYPOGRAPHY                                     -->
    <!-- ═══════════════════════════════════════════════ -->
    <Style TargetType="Label" ApplyToDerivedTypes="True">
        <Setter Property="TextColor" Value="{DynamicResource TextPrimary}" />
        <Setter Property="FontFamily" Value="OpenSansRegular" />
        <Setter Property="LineHeight" Value="1.4" />
    </Style>

    <!-- Display: hero titles on auth screens -->
    <Style x:Key="DisplayLabel" TargetType="Label">
        <Setter Property="FontSize" Value="36" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="TextColor" Value="{DynamicResource TextPrimary}" />
        <Setter Property="LineHeight" Value="1.2" />
    </Style>

    <!-- H1: page headers -->
    <Style x:Key="H1Label" TargetType="Label">
        <Setter Property="FontSize" Value="26" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="TextColor" Value="{DynamicResource TextPrimary}" />
        <Setter Property="LineHeight" Value="1.2" />
    </Style>

    <!-- H2: section titles -->
    <Style x:Key="H2Label" TargetType="Label">
        <Setter Property="FontSize" Value="20" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="TextColor" Value="{DynamicResource TextPrimary}" />
    </Style>

    <!-- Legacy alias -->
    <Style x:Key="HeadlineLabel" BasedOn="{StaticResource H1Label}" TargetType="Label" />
    <Style x:Key="TitleLabel" BasedOn="{StaticResource H2Label}" TargetType="Label" />

    <!-- Body -->
    <Style x:Key="BodyLabel" TargetType="Label">
        <Setter Property="FontSize" Value="15" />
        <Setter Property="TextColor" Value="{DynamicResource TextPrimary}" />
        <Setter Property="LineHeight" Value="1.6" />
    </Style>

    <!-- Secondary/hint text -->
    <Style x:Key="SubtitleLabel" TargetType="Label">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="TextColor" Value="{DynamicResource TextSecondary}" />
        <Setter Property="LineHeight" Value="1.4" />
    </Style>

    <!-- Caption -->
    <Style x:Key="CaptionLabel" TargetType="Label">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="TextColor" Value="{DynamicResource TextTertiary}" />
    </Style>

    <!-- Price -->
    <Style x:Key="PriceLabel" TargetType="Label">
        <Setter Property="FontSize" Value="22" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="TextColor" Value="{DynamicResource Primary}" />
    </Style>

    <!-- Error text -->
    <Style x:Key="ErrorLabel" TargetType="Label">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="TextColor" Value="{DynamicResource Error}" />
    </Style>

    <!-- ═══════════════════════════════════════════════ -->
    <!--  CARDS                                          -->
    <!-- ═══════════════════════════════════════════════ -->
    <!-- Standard card (Border-based, keep Frame aliases for legacy) -->
    <Style x:Key="CardFrame" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{DynamicResource Surface}" />
        <Setter Property="StrokeShape" Value="RoundRectangle 16" />
        <Setter Property="Stroke" Value="{DynamicResource Border}" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Margin" Value="0,6" />
    </Style>

    <!-- ═══════════════════════════════════════════════ -->
    <!--  BUTTONS                                        -->
    <!-- ═══════════════════════════════════════════════ -->
    <!-- Primary CTA -->
    <Style x:Key="PrimaryButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{DynamicResource Primary}" />
        <Setter Property="TextColor" Value="#FFFFFF" />
        <Setter Property="CornerRadius" Value="14" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="HeightRequest" Value="52" />
        <Setter Property="Padding" Value="24,0" />
        <Setter Property="Shadow">
            <Setter.Value>
                <Shadow Brush="{StaticResource Primary}" Offset="0,4" Radius="12" Opacity="0.35" />
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Secondary outlined -->
    <Style x:Key="SecondaryButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="TextColor" Value="{DynamicResource Primary}" />
        <Setter Property="BorderColor" Value="{StaticResource Primary}" />
        <Setter Property="BorderWidth" Value="1.5" />
        <Setter Property="CornerRadius" Value="14" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="HeightRequest" Value="52" />
        <Setter Property="Padding" Value="24,0" />
    </Style>

    <!-- Ghost / text button -->
    <Style x:Key="GhostButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="TextColor" Value="{DynamicResource Primary}" />
        <Setter Property="BorderWidth" Value="0" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="HeightRequest" Value="40" />
        <Setter Property="Padding" Value="12,0" />
    </Style>

    <!-- Danger -->
    <Style x:Key="DangerButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{DynamicResource Error}" />
        <Setter Property="TextColor" Value="#FFFFFF" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="HeightRequest" Value="40" />
        <Setter Property="Padding" Value="14,0" />
    </Style>

    <!-- Success -->
    <Style x:Key="SuccessButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{DynamicResource Success}" />
        <Setter Property="TextColor" Value="#FFFFFF" />
        <Setter Property="CornerRadius" Value="14" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="HeightRequest" Value="52" />
        <Setter Property="Padding" Value="24,0" />
    </Style>

    <!-- ═══════════════════════════════════════════════ -->
    <!--  INPUTS                                         -->
    <!-- ═══════════════════════════════════════════════ -->
    <Style x:Key="ModernEntry" TargetType="Entry">
        <Setter Property="BackgroundColor" Value="{DynamicResource SurfaceVariant}" />
        <Setter Property="TextColor" Value="{DynamicResource TextPrimary}" />
        <Setter Property="PlaceholderColor" Value="{DynamicResource TextTertiary}" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="HeightRequest" Value="52" />
        <Setter Property="Margin" Value="0,2" />
    </Style>

    <Style x:Key="ModernEditor" TargetType="Editor">
        <Setter Property="BackgroundColor" Value="{DynamicResource SurfaceVariant}" />
        <Setter Property="TextColor" Value="{DynamicResource TextPrimary}" />
        <Setter Property="PlaceholderColor" Value="{DynamicResource TextTertiary}" />
        <Setter Property="FontSize" Value="15" />
    </Style>

    <Style x:Key="ModernPicker" TargetType="Picker">
        <Setter Property="BackgroundColor" Value="{DynamicResource SurfaceVariant}" />
        <Setter Property="TextColor" Value="{DynamicResource TextPrimary}" />
        <Setter Property="TitleColor" Value="{DynamicResource TextTertiary}" />
    </Style>

    <!-- ═══════════════════════════════════════════════ -->
    <!--  CHIPS & BADGES                                 -->
    <!-- ═══════════════════════════════════════════════ -->
    <Style x:Key="Chip" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{DynamicResource SurfaceVariant}" />
        <Setter Property="StrokeShape" Value="RoundRectangle 20" />
        <Setter Property="Stroke" Value="{StaticResource Border}" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="Padding" Value="12,6" />
        <Setter Property="Margin" Value="0,0,6,0" />
    </Style>

    <Style x:Key="PrimaryChip" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{DynamicResource PrimarySubtle}" />
        <Setter Property="StrokeShape" Value="RoundRectangle 20" />
        <Setter Property="Stroke" Value="Transparent" />
        <Setter Property="StrokeThickness" Value="0" />
        <Setter Property="Padding" Value="12,6" />
        <Setter Property="Margin" Value="0,0,6,0" />
    </Style>

    <!-- ═══════════════════════════════════════════════ -->
    <!--  INPUT LABEL (field label above entry)         -->
    <!-- ═══════════════════════════════════════════════ -->
    <Style x:Key="FieldLabel" TargetType="Label">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="TextColor" Value="{DynamicResource TextSecondary}" />
        <Setter Property="Margin" Value="4,8,0,4" />
    </Style>

    <!-- ═══════════════════════════════════════════════ -->
    <!--  DIVIDER                                        -->
    <!-- ═══════════════════════════════════════════════ -->
    <Style x:Key="HDivider" TargetType="BoxView">
        <Setter Property="HeightRequest" Value="1" />
        <Setter Property="Color" Value="{DynamicResource Divider}" />
        <Setter Property="HorizontalOptions" Value="Fill" />
        <Setter Property="Margin" Value="0,8" />
    </Style>

    <!-- ═══════════════════════════════════════════════ -->
    <!--  ACTIVITY INDICATOR                             -->
    <!-- ═══════════════════════════════════════════════ -->
    <Style TargetType="ActivityIndicator">
        <Setter Property="Color" Value="{DynamicResource Primary}" />
        <Setter Property="HorizontalOptions" Value="Center" />
        <Setter Property="Margin" Value="0,8" />
    </Style>

</ResourceDictionary>
