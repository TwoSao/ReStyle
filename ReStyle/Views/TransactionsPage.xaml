<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:dto="clr-namespace:ReStyle.Application.DTOs"
             x:Class="ReStyle.Views.TransactionsPage"
             Title="Transactions">

    <Grid RowDefinitions="Auto,*">

        <!-- Tab selector -->
        <HorizontalStackLayout Grid.Row="0" Margin="16,12" Spacing="8">
            <Button Text="Purchases" Style="{StaticResource PrimaryButton}"
                    HeightRequest="40" Padding="20,0" Clicked="OnPurchasesTab" x:Name="PurchasesBtn" />
            <Button Text="Sales" Style="{StaticResource SecondaryButton}"
                    HeightRequest="40" Padding="20,0" Clicked="OnSalesTab" x:Name="SalesBtn" />
        </HorizontalStackLayout>

        <CollectionView Grid.Row="1" x:Name="TransactionsList" Margin="16,0">
            <CollectionView.EmptyView>
                <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Margin="0,60" Spacing="12">
                    <Label Text="📋" FontSize="64" HorizontalOptions="Center" />
                    <Label Text="No transactions yet" Style="{StaticResource TitleLabel}" HorizontalOptions="Center" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="dto:TransactionDto">
                    <Frame Style="{StaticResource CardFrame}" Padding="16">
                        <Grid ColumnDefinitions="*,Auto">
                            <VerticalStackLayout Grid.Column="0" Spacing="4">
                                <Label Text="{Binding ItemTitle}" Style="{StaticResource TitleLabel}" FontSize="15" />
                                <Label Text="{Binding TransactionDate, StringFormat='{0:MMM dd, yyyy}'}"
                                       Style="{StaticResource SubtitleLabel}" FontSize="12" />
                                <Label Text="{Binding BuyerUsername, StringFormat='Buyer: {0}'}"
                                       Style="{StaticResource SubtitleLabel}" FontSize="12" />
                            </VerticalStackLayout>
                            <Label Grid.Column="1" Text="{Binding Amount, StringFormat='${0:F2}'}"
                                   Style="{StaticResource PriceLabel}" VerticalOptions="Center" />
                        </Grid>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>

</ContentPage>
