<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:conv="clr-namespace:ReStyle.Converters"
             x:Class="ReStyle.Views.ProfilePage"
             Title="Profile">

    <ContentPage.Resources>
        <conv:InverseBoolConverter x:Key="InverseBoolConverter" />
        <conv:NullToFalseConverter x:Key="NullToFalseConverter" />
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Spacing="0">

            <!-- ══════════════════════════════════ -->
            <!--              GUEST                 -->
            <!-- ══════════════════════════════════ -->
            <VerticalStackLayout IsVisible="{Binding IsGuest}" Spacing="0">

                <!-- Header -->
                <Grid BackgroundColor="{StaticResource Primary}" Padding="24,40,24,32">
                    <VerticalStackLayout Spacing="10" HorizontalOptions="Center">
                        <Border StrokeShape="RoundRectangle 50"
                                Stroke="White" StrokeThickness="3"
                                WidthRequest="80" HeightRequest="80"
                                HorizontalOptions="Center"
                                BackgroundColor="#FFFFFF22">
                            <Label Text="👤" FontSize="36"
                                   HorizontalOptions="Center" VerticalOptions="Center" />
                        </Border>
                        <Label Text="Guest" FontSize="22" FontAttributes="Bold"
                               TextColor="White" HorizontalOptions="Center" />
                        <Label Text="Not signed in" FontSize="13" TextColor="#CCFFFFFF"
                               HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </Grid>

                <!-- Benefits card -->
                <VerticalStackLayout Padding="20" Spacing="12">
                    <Frame Style="{StaticResource CardFrame}" Padding="20">
                        <VerticalStackLayout Spacing="10">
                            <Label Text="Join ReStyle" Style="{StaticResource TitleLabel}" />
                            <Label Text="✅  Buy and sell fashion items" Style="{StaticResource SubtitleLabel}" />
                            <Label Text="✅  Track your transactions" Style="{StaticResource SubtitleLabel}" />
                            <Label Text="✅  Manage your listings" Style="{StaticResource SubtitleLabel}" />
                            <Label Text="✅  Top up your balance" Style="{StaticResource SubtitleLabel}" />
                        </VerticalStackLayout>
                    </Frame>

                    <Button Text="Sign In" Style="{StaticResource PrimaryButton}"
                            Command="{Binding GoToLoginCommand}" />
                    <Button Text="Create Account" Style="{StaticResource SecondaryButton}"
                            Command="{Binding GoToRegisterCommand}" />
                </VerticalStackLayout>

            </VerticalStackLayout>

            <!-- ══════════════════════════════════ -->
            <!--              USER                  -->
            <!-- ══════════════════════════════════ -->
            <VerticalStackLayout IsVisible="{Binding IsUser}" Spacing="0">

                <!-- Header -->
                <Grid BackgroundColor="{StaticResource Primary}" Padding="24,40,24,32">
                    <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                        <Border StrokeShape="RoundRectangle 50"
                                Stroke="White" StrokeThickness="3"
                                WidthRequest="80" HeightRequest="80"
                                HorizontalOptions="Center"
                                BackgroundColor="#FFFFFF22">
                            <Label Text="👤" FontSize="36"
                                   HorizontalOptions="Center" VerticalOptions="Center" />
                        </Border>
                        <Label Text="{Binding Username}" FontSize="22" FontAttributes="Bold"
                               TextColor="White" HorizontalOptions="Center" />
                        <Border StrokeShape="RoundRectangle 20"
                                BackgroundColor="#FFFFFF22" Stroke="Transparent"
                                Padding="10,4" HorizontalOptions="Center">
                            <Label Text="{Binding Role}" FontSize="12" TextColor="White" />
                        </Border>
                    </VerticalStackLayout>
                </Grid>

                <VerticalStackLayout Padding="20" Spacing="12">

                    <!-- Balance card -->
                    <Frame Style="{StaticResource CardFrame}" Padding="20">
                        <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
                            <Label Grid.Row="0" Grid.Column="0"
                                   Text="Balance" Style="{StaticResource SubtitleLabel}" />
                            <Label Grid.Row="1" Grid.Column="0"
                                   Text="{Binding Balance, StringFormat='${0:F2}'}"
                                   FontSize="28" FontAttributes="Bold"
                                   TextColor="{StaticResource Primary}" />
                            <Button Grid.Row="0" Grid.Column="1" Grid.RowSpan="2"
                                    Text="Top Up" Style="{StaticResource PrimaryButton}"
                                    HeightRequest="44" Padding="16,0"
                                    VerticalOptions="Center"
                                    Command="{Binding GoToBalanceCommand}" />
                        </Grid>
                    </Frame>

                    <!-- Edit profile -->
                    <Frame Style="{StaticResource CardFrame}" Padding="20">
                        <VerticalStackLayout Spacing="10">
                            <Label Text="Edit Profile" Style="{StaticResource TitleLabel}" FontSize="16" />
                            <Entry Placeholder="Username" Text="{Binding Username}"
                                   Style="{StaticResource ModernEntry}" />
                            <Entry Placeholder="Email" Text="{Binding Email}"
                                   Keyboard="Email" Style="{StaticResource ModernEntry}" />
                            <Label Text="{Binding ErrorMessage}" TextColor="{StaticResource Error}"
                                   IsVisible="{Binding ErrorMessage, Converter={StaticResource NullToFalseConverter}}" />
                            <Button Text="Save Changes" Style="{StaticResource PrimaryButton}"
                                    Command="{Binding SaveProfileCommand}"
                                    IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}" />
                        </VerticalStackLayout>
                    </Frame>

                    <!-- Actions -->
                    <Frame Style="{StaticResource CardFrame}" Padding="4">
                        <VerticalStackLayout Spacing="0">
                            <Button Text="📋  Transaction History"
                                    BackgroundColor="Transparent"
                                    TextColor="{StaticResource TextPrimary}"
                                    HorizontalOptions="Fill" HeightRequest="52"
                                    FontSize="15"
                                    Command="{Binding GoToTransactionsCommand}" />
                            <BoxView HeightRequest="1" Color="{StaticResource Divider}" Margin="16,0" />
                            <Button Text="🛡️  Admin Panel"
                                    IsVisible="{Binding IsAdmin}"
                                    BackgroundColor="Transparent"
                                    TextColor="{StaticResource TextPrimary}"
                                    HorizontalOptions="Fill" HeightRequest="52"
                                    FontSize="15"
                                    Command="{Binding GoToAdminCommand}" />
                        </VerticalStackLayout>
                    </Frame>

                    <Button Text="Sign Out" Style="{StaticResource DangerButton}"
                            HeightRequest="52" FontSize="16"
                            HorizontalOptions="Fill"
                            Command="{Binding LogoutCommand}" />

                </VerticalStackLayout>
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
