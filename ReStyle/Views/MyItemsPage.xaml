<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:dto="clr-namespace:ReStyle.Application.DTOs"
             xmlns:conv="clr-namespace:ReStyle.Converters"
             x:Class="ReStyle.Views.MyItemsPage"
             Title="My Listings">

    <ContentPage.Resources>
        <conv:ImagePathConverter x:Key="ImagePathConverter" />
        <conv:ItemStatusToColorConverter x:Key="StatusColorConverter" />
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*">

        <Button Grid.Row="0" Text="+ New Listing" Style="{StaticResource PrimaryButton}"
                Command="{Binding AddItemCommand}" Margin="16,12" />

        <CollectionView Grid.Row="1" ItemsSource="{Binding Items}" Margin="16,0">
            <CollectionView.EmptyView>
                <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Margin="0,60" Spacing="12">
                    <Label Text="🛍️" FontSize="64" HorizontalOptions="Center" />
                    <Label Text="No listings yet" Style="{StaticResource TitleLabel}" HorizontalOptions="Center" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="dto:ItemDto">
                    <Frame Style="{StaticResource CardFrame}" Padding="12">
                        <Grid ColumnDefinitions="80,*,Auto" ColumnSpacing="12">
                            <Image Grid.Column="0" Source="{Binding ImagePath, Converter={StaticResource ImagePathConverter}}"
                                   WidthRequest="80" HeightRequest="80" Aspect="AspectFill" />
                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="4">
                                <Label Text="{Binding Title}" Style="{StaticResource TitleLabel}" FontSize="15"
                                       LineBreakMode="TailTruncation" MaxLines="1" />
                                <Label Text="{Binding Price, StringFormat='${0:F2}'}" Style="{StaticResource PriceLabel}" FontSize="15" />
                                <Frame Padding="6,2" CornerRadius="6" HasShadow="False"
                                       BackgroundColor="{Binding Status, Converter={StaticResource StatusColorConverter}}"
                                       HorizontalOptions="Start">
                                    <Label Text="{Binding Status}" TextColor="White" FontSize="11" />
                                </Frame>
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="2" VerticalOptions="Center" Spacing="6">
                                <Button Text="Edit" Style="{StaticResource SecondaryButton}"
                                        HeightRequest="36" Padding="12,0"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.EditItemCommand}"
                                        CommandParameter="{Binding .}" />
                                <Button Text="Delete" Style="{StaticResource DangerButton}"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.DeleteItemCommand}"
                                        CommandParameter="{Binding .}" />
                            </VerticalStackLayout>
                        </Grid>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>

</ContentPage>
