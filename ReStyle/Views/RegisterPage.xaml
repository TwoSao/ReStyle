<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ReStyle.Views.RegisterPage"
             Title=""
             Shell.NavBarIsVisible="False">

    <ScrollView>
        <VerticalStackLayout Padding="32,60,32,32" Spacing="0">

            <Label Text="ReStyle" FontSize="42" FontAttributes="Bold"
                   TextColor="{StaticResource Primary}" HorizontalOptions="Center" />
            <Label Text="Join the community" Style="{StaticResource SubtitleLabel}"
                   HorizontalOptions="Center" Margin="0,4,0,48" />

            <Frame Style="{StaticResource CardFrame}" Padding="24">
                <VerticalStackLayout Spacing="12">
                    <Label Text="Create Account" Style="{StaticResource TitleLabel}" />

                    <Entry Placeholder="Username" Text="{Binding Username}" Style="{StaticResource ModernEntry}" />
                    <Entry Placeholder="Email" Text="{Binding Email}" Keyboard="Email" Style="{StaticResource ModernEntry}" />
                    <Entry Placeholder="Password" Text="{Binding Password}" IsPassword="True" Style="{StaticResource ModernEntry}" />
                    <Entry Placeholder="Confirm Password" Text="{Binding ConfirmPassword}" IsPassword="True" Style="{StaticResource ModernEntry}" />

                    <Label Text="{Binding ErrorMessage}" TextColor="{StaticResource Error}"
                           IsVisible="{Binding ErrorMessage, Converter={StaticResource NullToFalseConverter}}"
                           FontSize="13" Margin="0,4" />

                    <Button Text="Create Account" Style="{StaticResource PrimaryButton}"
                            Command="{Binding RegisterCommand}"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"
                            Margin="0,8,0,0" />

                    <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}"
                                       Color="{StaticResource Primary}" HorizontalOptions="Center" />
                </VerticalStackLayout>
            </Frame>

            <HorizontalStackLayout HorizontalOptions="Center" Margin="0,24,0,0" Spacing="4">
                <Label Text="Already have an account?" Style="{StaticResource SubtitleLabel}" VerticalOptions="Center" />
                <Button Text="Sign In" Command="{Binding GoToLoginCommand}"
                        HeightRequest="36" Padding="12,0" BorderWidth="0"
                        TextColor="{StaticResource Primary}" BackgroundColor="Transparent" />
            </HorizontalStackLayout>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
