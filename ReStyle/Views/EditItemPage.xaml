<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:conv="clr-namespace:ReStyle.Converters"
             x:Class="ReStyle.Views.EditItemPage"
             Title="Edit Listing">

    <ContentPage.Resources>
        <conv:ImagePathConverter x:Key="ImagePathConverter" />
        <conv:NullToFalseConverter x:Key="NullToFalseConverter" />
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="16">

            <Frame Style="{StaticResource CardFrame}" HeightRequest="200" Padding="0">
                <Grid>
                    <Image Source="{Binding ImagePath, Converter={StaticResource ImagePathConverter}}"
                           Aspect="AspectFill" />
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding PickImageCommand}" />
                    </Grid.GestureRecognizers>
                </Grid>
            </Frame>

            <Label Text="Title" Style="{StaticResource SubtitleLabel}" />
            <Entry Text="{Binding Title}" Style="{StaticResource ModernEntry}" />

            <Label Text="Description" Style="{StaticResource SubtitleLabel}" />
            <Editor Text="{Binding Description}" HeightRequest="100"
                    BackgroundColor="{StaticResource SurfaceVariant}"
                    TextColor="{StaticResource TextPrimary}" />

            <Label Text="Price ($)" Style="{StaticResource SubtitleLabel}" />
            <Entry Text="{Binding Price}" Keyboard="Numeric" Style="{StaticResource ModernEntry}" />

            <Label Text="Category" Style="{StaticResource SubtitleLabel}" />
            <Picker ItemsSource="{Binding Categories}" SelectedItem="{Binding Category}"
                    TextColor="{StaticResource TextPrimary}" BackgroundColor="{StaticResource SurfaceVariant}" />

            <Label Text="Size" Style="{StaticResource SubtitleLabel}" />
            <Picker ItemsSource="{Binding Sizes}" SelectedItem="{Binding Size}"
                    TextColor="{StaticResource TextPrimary}" BackgroundColor="{StaticResource SurfaceVariant}" />

            <Label Text="{Binding ErrorMessage}" TextColor="{StaticResource Error}"
                   IsVisible="{Binding ErrorMessage, Converter={StaticResource NullToFalseConverter}}" />

            <Button Text="Save Changes" Style="{StaticResource PrimaryButton}" Command="{Binding SaveCommand}" />
            <Button Text="Cancel" Style="{StaticResource SecondaryButton}" Command="{Binding CancelCommand}" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
