<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:ReStyle.ViewModels"
             x:Class="ReStyle.Views.LoginPage"
             Title=""
             Shell.NavBarIsVisible="False">

    <ScrollView>
        <VerticalStackLayout Padding="32,60,32,32" Spacing="0">

            <!-- Logo / Brand -->
            <Label Text="ReStyle" FontSize="42" FontAttributes="Bold"
                   TextColor="{StaticResource Primary}" HorizontalOptions="Center" />
            <Label Text="Buy &amp; Sell Fashion" Style="{StaticResource SubtitleLabel}"
                   HorizontalOptions="Center" Margin="0,4,0,48" />

            <!-- Form Card -->
            <Frame Style="{StaticResource CardFrame}" Padding="24">
                <VerticalStackLayout Spacing="12">
                    <Label Text="Welcome back" Style="{StaticResource TitleLabel}" />
                    <Label Text="Sign in to your account" Style="{StaticResource SubtitleLabel}" Margin="0,0,0,8" />

                    <Entry Placeholder="Email" Text="{Binding Email}"
                           Keyboard="Email" Style="{StaticResource ModernEntry}" />

                    <Entry Placeholder="Password" Text="{Binding Password}"
                           IsPassword="True" Style="{StaticResource ModernEntry}" />

                    <Label Text="{Binding ErrorMessage}" TextColor="{StaticResource Error}"
                           IsVisible="{Binding ErrorMessage, Converter={StaticResource NullToFalseConverter}}"
                           FontSize="13" Margin="0,4" />

                    <Button Text="Sign In" Style="{StaticResource PrimaryButton}"
                            Command="{Binding LoginCommand}"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"
                            Margin="0,8,0,0" />

                    <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}"
                                       Color="{StaticResource Primary}" HorizontalOptions="Center" />
                </VerticalStackLayout>
            </Frame>

            <!-- Register link -->
            <HorizontalStackLayout HorizontalOptions="Center" Margin="0,24,0,0" Spacing="4">
                <Label Text="Don't have an account?" Style="{StaticResource SubtitleLabel}" VerticalOptions="Center" />
                <Button Text="Register" Style="{StaticResource SecondaryButton}"
                        Command="{Binding GoToRegisterCommand}"
                        HeightRequest="36" Padding="12,0" BorderWidth="0"
                        TextColor="{StaticResource Primary}" BackgroundColor="Transparent" />
            </HorizontalStackLayout>

            <!-- Guest mode -->
            <Button Text="Browse as Guest" Style="{StaticResource SecondaryButton}"
                    Margin="0,8,0,0"
                    Command="{Binding GoToRegisterCommand}" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
