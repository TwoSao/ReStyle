<?xml version="1.0" encoding="UTF-8" ?>
<Shell xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
       xmlns:views="clr-namespace:ReStyle.Views"
       x:Class="ReStyle.AppShell"
       Title="ReStyle">

    <!-- Auth routes (no tab bar) -->
    <ShellContent Route="login" Shell.NavBarIsVisible="False"
                  ContentTemplate="{DataTemplate views:LoginPage}" />
    <ShellContent Route="register" Shell.NavBarIsVisible="False"
                  ContentTemplate="{DataTemplate views:RegisterPage}" />

    <!-- Main Tab Bar -->
    <TabBar>
        <Tab Title="Home" Icon="home.png">
            <ShellContent Route="home" ContentTemplate="{DataTemplate views:HomePage}" />
        </Tab>
        <Tab Title="My Items" Icon="bag.png">
            <ShellContent Route="myitems" ContentTemplate="{DataTemplate views:MyItemsPage}" />
        </Tab>
        <Tab Title="Transactions" Icon="receipt.png">
            <ShellContent Route="transactions" ContentTemplate="{DataTemplate views:TransactionsPage}" />
        </Tab>
        <Tab Title="Balance" Icon="wallet.png">
            <ShellContent Route="balance" ContentTemplate="{DataTemplate views:BalancePage}" />
        </Tab>
        <Tab Title="Profile" Icon="person.png">
            <ShellContent Route="profile" ContentTemplate="{DataTemplate views:ProfilePage}" />
        </Tab>
    </TabBar>

</Shell>
